pipeline {
    agent any

    environment {
        AWS_DEFAULT_REGION = 'ap-south-1'
        AWS_REGION         = 'ap-south-1'
        CLUSTER_NAME       = 'mypythonapp.k8s.local'
        TF_DIR             = 'terraform'
        KUBECONFIG         = '/var/lib/jenkins/.kube/config'
    }

    stages {

        stage('Terraform Init') {
            steps {
                dir("${TF_DIR}") {
                    sh 'terraform init -reconfigure'
                }
            }
        }

        stage('Terraform Validate') {
            steps {
                dir("${TF_DIR}") {
                    sh 'terraform validate'
                }
            }
        }

        stage('Terraform Apply') {
            steps {
                dir("${TF_DIR}") {
                    sh 'terraform apply -auto-approve'
                }
            }
        }

        stage('Get Terraform Outputs') {
            steps {
                script {
                    env.KOPS_STATE_STORE = "s3://" + sh(
                        script: "cd ${TF_DIR} && terraform output -raw kops_bucket_name",
                        returnStdout: true
                    ).trim()

                    env.VPC_ID = sh(
                        script: "cd ${TF_DIR} && terraform output -raw vpc_id",
                        returnStdout: true
                    ).trim()

                    env.SUBNETS = sh(
                        script: "cd ${TF_DIR} && terraform output -json private_subnet_ids | jq -r '.[0]'",
                        returnStdout: true
                    ).trim()

                    env.UTILITY_SUBNETS = sh(
                        script: "cd ${TF_DIR} && terraform output -json public_subnet_ids | jq -r '.[0]'",
                        returnStdout: true
                    ).trim()

                    echo "KOPS_STATE_STORE: ${env.KOPS_STATE_STORE}"
                    echo "VPC_ID: ${env.VPC_ID}"
                    echo "SUBNETS: ${env.SUBNETS}"
                    echo "UTILITY_SUBNETS: ${env.UTILITY_SUBNETS}"
                }
            }
        }

        stage('kOps — Create or Update Cluster') {
            steps {
                script {
                    def clusterExists = sh(
                        script: "kops get cluster --name=${CLUSTER_NAME} --state=${env.KOPS_STATE_STORE} > /dev/null 2>&1 && echo 'yes' || echo 'no'",
                        returnStdout: true
                    ).trim()

                    if (clusterExists == 'yes') {
                        echo "Cluster exists — running update..."
                        sh """
                            kops update cluster \\
                            --name=${CLUSTER_NAME} \\
                            --state=${env.KOPS_STATE_STORE} \\
                            --yes

                            kops rolling-update cluster \\
                            --name=${CLUSTER_NAME} \\
                            --state=${env.KOPS_STATE_STORE} \\
                            --yes
                        """
                    } else {
                        echo "Cluster not found — creating..."
                        sh """
                            kops create cluster \\
                            --name=${CLUSTER_NAME} \\
                            --state=${env.KOPS_STATE_STORE} \\
                            --network-id=${env.VPC_ID} \\
                            --subnets=${env.SUBNETS} \\
                            --utility-subnets=${env.UTILITY_SUBNETS} \\
                            --control-plane-size=t3.small \\
                            --node-size=t3.small \\
                            --node-count=2 \\
                            --zones=${AWS_REGION}a \\
                            --topology=private \\
                            --networking=calico \\
                            --yes
                        """
                    }
                }
            }
        }

        stage('Allow Jenkins to K8s API') {
            steps {
                script {
                    // Get Jenkins private IP
                    def jenkinsIp = sh(
                        script: "curl -s http://169.254.169.254/latest/meta-data/local-ipv4",
                        returnStdout: true
                    ).trim()

                    // Get kops API ELB security group ID
                    def apiElbSgId = sh(
                        script: """
                            aws ec2 describe-security-groups \
                            --filters "Name=tag:KubernetesCluster,Values=${CLUSTER_NAME}" \
                                        "Name=group-name,Values=api-elb.${CLUSTER_NAME}" \
                            --query "SecurityGroups[0].GroupId" \
                            --output text \
                            --region ${AWS_DEFAULT_REGION}
                        """,
                        returnStdout: true
                    ).trim()

                    echo "Jenkins IP: ${jenkinsIp}"
                    echo "API ELB SG: ${apiElbSgId}"

                    // Add rule — ignore error if rule already exists
                    sh """
                        aws ec2 authorize-security-group-ingress \
                        --group-id ${apiElbSgId} \
                        --protocol tcp \
                        --port 443 \
                        --cidr ${jenkinsIp}/32 \
                        --region ${AWS_DEFAULT_REGION} || true
                    """
                }
            }
        }

        stage('kOps — Validate Cluster') {
            steps {
                sh """
                    kops validate cluster \
                    --name=${CLUSTER_NAME} \
                    --state=${env.KOPS_STATE_STORE} \
                    --wait=10m
                """
            }
        }

        stage('Export kubeconfig to Jenkins') {
            steps {
                sh """
                    mkdir -p /var/lib/jenkins/.kube

                    kops export kubecfg \\
                      --name=${CLUSTER_NAME} \\
                      --state=${env.KOPS_STATE_STORE} \\
                      --admin

                    echo "kubeconfig written to /var/lib/jenkins/.kube/config"
                    kubectl get nodes
                """
            }
        }
    }

    post {
        success {
            echo "Infrastructure and cluster are ready. kubeconfig available for application pipelines."
        }
        failure {
            echo "Pipeline failed. Check logs above."
        }
        always {
            cleanWs()
        }
    }
}
