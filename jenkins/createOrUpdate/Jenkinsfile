pipeline {
    agent any

    environment {
        AWS_DEFAULT_REGION = 'ap-south-1'
        AWS_REGION         = 'ap-south-1'
        CLUSTER_NAME       = 'mypythonapp.k8s.local'
        TF_DIR             = 'terraform'
        KUBECONFIG         = '/var/lib/jenkins/.kube/config'
    }

    stages {

        stage('Terraform Init') {
            steps {
                dir("${TF_DIR}") {
                    sh 'terraform init -reconfigure'
                }
            }
        }

        stage('Terraform Validate') {
            steps {
                dir("${TF_DIR}") {
                    sh 'terraform validate'
                }
            }
        }

        stage('Terraform Apply') {
            steps {
                dir("${TF_DIR}") {
                    sh 'terraform apply -auto-approve'
                }
            }
        }

        stage('Get Terraform Outputs') {
            steps {
                script {
                    env.KOPS_STATE_STORE = "s3://" + sh(
                        script: "cd ${TF_DIR} && terraform output -raw kops_bucket_name",
                        returnStdout: true
                    ).trim()

                    env.VPC_ID = sh(
                        script: "cd ${TF_DIR} && terraform output -raw vpc_id",
                        returnStdout: true
                    ).trim()

                    env.SUBNETS = sh(
                        script: "cd ${TF_DIR} && terraform output -json private_subnet_ids | jq -r '.[0]'",
                        returnStdout: true
                    ).trim()

                    env.UTILITY_SUBNETS = sh(
                        script: "cd ${TF_DIR} && terraform output -json public_subnet_ids | jq -r '.[0]'",
                        returnStdout: true
                    ).trim()

                    echo "KOPS_STATE_STORE: ${env.KOPS_STATE_STORE}"
                    echo "VPC_ID: ${env.VPC_ID}"
                    echo "SUBNETS: ${env.SUBNETS}"
                    echo "UTILITY_SUBNETS: ${env.UTILITY_SUBNETS}"
                }
            }
        }

        stage('kOps — Create or Update Cluster') {
            steps {
                script {
                    def clusterExists = sh(
                        script: "kops get cluster --name=${CLUSTER_NAME} --state=${env.KOPS_STATE_STORE} > /dev/null 2>&1 && echo 'yes' || echo 'no'",
                        returnStdout: true
                    ).trim()

                    env.CLUSTER_EXISTS = clusterExists  // store for later stages

                    if (clusterExists == 'yes') {
                        echo "Cluster exists — running update..."
                        sh """
                            kops update cluster \
                              --name=${CLUSTER_NAME} \
                              --state=${env.KOPS_STATE_STORE} \
                              --yes

                            kops export kubecfg \
                              --name=${CLUSTER_NAME} \
                              --state=${env.KOPS_STATE_STORE} \
                              --admin
                        """
                    } else {
                        echo "Cluster not found — creating..."
                        sh """
                            kops create cluster \
                              --name=${CLUSTER_NAME} \
                              --state=${env.KOPS_STATE_STORE} \
                              --network-id=${env.VPC_ID} \
                              --subnets=${env.SUBNETS} \
                              --utility-subnets=${env.UTILITY_SUBNETS} \
                              --control-plane-size=t3.small \
                              --node-size=t3.small \
                              --node-count=2 \
                              --zones=ap-south-1a \
                              --topology=private \
                              --networking=calico \
                              --yes

                            kops export kubecfg \
                              --name=${CLUSTER_NAME} \
                              --state=${env.KOPS_STATE_STORE} \
                              --admin
                        """
                    }
                }
            }
        }

        stage('Allow Jenkins to K8s API') {
            steps {
                script {
                    def jenkinsIp = sh(
                        script: """
                            TOKEN=\$(curl -s -X PUT "http://169.254.169.254/latest/api/token" \
                              -H "X-aws-ec2-metadata-token-ttl-seconds: 21600")
                            curl -s -H "X-aws-ec2-metadata-token: \$TOKEN" \
                              http://169.254.169.254/latest/meta-data/local-ipv4
                        """,
                        returnStdout: true
                    ).trim()

                    def apiElbSgId = sh(
                        script: """
                            aws ec2 describe-security-groups \
                              --filters "Name=tag:KubernetesCluster,Values=${CLUSTER_NAME}" \
                                        "Name=group-name,Values=api-elb.${CLUSTER_NAME}" \
                              --query "SecurityGroups[0].GroupId" \
                              --output text \
                              --region ${AWS_DEFAULT_REGION}
                        """,
                        returnStdout: true
                    ).trim()

                    echo "Jenkins IP: ${jenkinsIp}"
                    echo "API ELB SG: ${apiElbSgId}"

                    // || true — prevents failure if rule already exists
                    sh """
                        aws ec2 authorize-security-group-ingress \
                          --group-id ${apiElbSgId} \
                          --protocol tcp \
                          --port 443 \
                          --cidr ${jenkinsIp}/32 \
                          --region ${AWS_DEFAULT_REGION} || true
                    """
                }
            }
        }

        stage('kOps — Validate Cluster') {
            steps {
                sh """
                    kops validate cluster \
                      --name=${CLUSTER_NAME} \
                      --state=${env.KOPS_STATE_STORE} \
                      --wait=15m
                """
            }
        }
        stage('Install Nginx Ingress Controller') {
            steps {
                script {
                    def ingressExists = sh(
                        script: "kubectl get ns ingress-nginx > /dev/null 2>&1 && echo 'yes' || echo 'no'",
                        returnStdout: true
                    ).trim()

                    if (ingressExists == 'yes') {
                        echo "Nginx Ingress Controller already installed — skipping."
                    } else {
                        echo "Installing Nginx Ingress Controller..."
                        sh """
                            # Install via Helm with public subnet annotation
                            helm repo add ingress-nginx https://kubernetes.github.io/ingress-nginx
                            helm repo update

                            helm install ingress-nginx ingress-nginx/ingress-nginx \
                            --namespace ingress-nginx \
                            --create-namespace \
                            --set controller.service.type=LoadBalancer \
                            --set controller.service.annotations."service\\.beta\\.kubernetes\\.io/aws-load-balancer-subnets"="${env.UTILITY_SUBNETS}" \
                            --set controller.service.annotations."service\\.beta\\.kubernetes\\.io/aws-load-balancer-scheme"="internet-facing" \
                            --wait \
                            --timeout=120s
                        """
                    }
                }
            }
        }   
        stage('kOps — Rolling Update') {
            // Only runs when cluster already existed (update path)
            // Skipped on fresh cluster creation
            when {
                expression { env.CLUSTER_EXISTS == 'yes' }
            }
            steps {
                sh """
                    kops rolling-update cluster \
                      --name=${CLUSTER_NAME} \
                      --state=${env.KOPS_STATE_STORE} \
                      --yes
                """
            }
        }

    }

    post {
        success {
            echo "Infrastructure and cluster are ready. kubeconfig available for application pipelines."
        }
        failure {
            echo "Pipeline failed. Check logs above."
        }
        always {
            cleanWs()
        }
    }
}