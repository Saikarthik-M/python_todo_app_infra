pipeline {
    agent any

    environment {
        AWS_REGION   = 'ap-south-1'
        CLUSTER_NAME = 'mycluster.pythonapp.com'
        TF_DIR       = 'terraform'
    }

    stages {

        stage('Get Terraform Outputs') {
            steps {
                script {
                    sh "cd ${TF_DIR} && terraform init -reconfigure"

                    env.KOPS_STATE_STORE = "s3://" + sh(
                        script: "cd ${TF_DIR} && terraform output -raw kops_bucket_name",
                        returnStdout: true
                    ).trim()

                    echo "KOPS_STATE_STORE: ${env.KOPS_STATE_STORE}"
                }
            }
        }

        stage('Verify kOps Cluster Exists') {
            steps {
                script {
                    def clusterExists = sh(
                        script: "kops get cluster --name=${CLUSTER_NAME} --state=${env.KOPS_STATE_STORE} > /dev/null 2>&1 && echo 'yes' || echo 'no'",
                        returnStdout: true
                    ).trim()

                    env.SKIP_KOPS = (clusterExists == 'no') ? 'true' : 'false'

                    if (clusterExists == 'no') {
                        echo "Cluster not found — skipping kOps delete."
                    } else {
                        echo "Cluster found — will delete."
                    }
                }
            }
        }

        stage('kOps — Delete Cluster') {
            when {
                expression { env.SKIP_KOPS == 'false' }
            }
            steps {
                sh """
                    kops delete cluster \\
                      --name=${CLUSTER_NAME} \\
                      --state=${env.KOPS_STATE_STORE} \\
                      --yes
                """
            }
        }

        stage('Verify kOps Resources Gone') {
            when {
                expression { env.SKIP_KOPS == 'false' }
            }
            steps {
                sh """
                    aws ec2 describe-instances \\
                      --region=${AWS_REGION} \\
                      --filters "Name=tag:KubernetesCluster,Values=${CLUSTER_NAME}" \\
                                "Name=instance-state-name,Values=running,pending,stopping" \\
                      --query 'Reservations[].Instances[].InstanceId' \\
                      --output text
                """
            }
        }

        stage('Terraform Init') {
            steps {
                dir("${TF_DIR}") {
                    sh 'terraform init -reconfigure'
                }
            }
        }

        stage('Terraform Destroy') {
            steps {
                dir("${TF_DIR}") {
                    sh 'terraform destroy -auto-approve'
                }
            }
        }
    }

    post {
        success {
            echo "All infrastructure destroyed successfully."
        }
        failure {
            echo "Destroy pipeline failed. Check AWS console for orphaned resources."
        }
        always {
            cleanWs()
        }
    }
}
